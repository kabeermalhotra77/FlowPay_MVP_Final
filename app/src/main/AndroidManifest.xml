<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required permissions for UPI123 payment system -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    

    <!-- Camera features for QR code scanning -->
    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlowPay"
        tools:targetApi="31">
        <activity
            android:name=".SetupActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay" />
        <activity
            android:name=".TestConfigurationActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FlowPay.Splash"
            android:label="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- QR Scanner Activity -->
        <activity
            android:name=".features.qr_scanner.presentation.QRScannerActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay"
            android:screenOrientation="portrait" />
        
        <!-- SMS Test Activity -->
        <activity
            android:name=".ui.activities.SMSTestActivity"
            android:exported="true"
            android:theme="@style/Theme.FlowPay"
            android:screenOrientation="portrait" />
        
        <!-- Call Overlay Activity -->
        <activity
            android:name=".ui.activities.CallOverlayActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:configChanges="orientation|keyboardHidden|screenSize" />
        
        <!-- Payment Processing Activity -->
        <activity
            android:name=".ui.activities.PaymentProcessingActivity"
            android:theme="@style/Theme.FlowPay"
            android:launchMode="singleTask" />
        
        <!-- Permission Guide Activity -->
        <activity
            android:name=".ui.activities.PermissionGuideActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay"
            android:screenOrientation="portrait" />
        
        <!-- Transaction Success Activity -->
        <activity
            android:name=".ui.activities.TransactionSuccessActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay"
            android:screenOrientation="portrait"
            android:launchMode="singleTask" />
        
        <!-- Payment Success Activity -->
        <activity
            android:name=".ui.activities.PaymentSuccessActivity"
            android:theme="@style/PaymentSuccessTheme"
            android:screenOrientation="portrait"
            android:launchMode="singleTask" />
        
        <!-- Transaction History Activity -->
        <activity
            android:name=".ui.activities.TransactionHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay"
            android:screenOrientation="portrait" />
        
        <!-- Settings Activity -->
        <activity
            android:name=".ui.activities.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.FlowPay"
            android:label="Settings"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>
        
        <!-- Call Overlay Service for UPI call protection -->
        <service
            android:name=".services.CallOverlayService"
            android:enabled="true"
            android:exported="false" />
        
        <!-- USSD Overlay Service for dynamic step-by-step instructions -->
        <!-- DISABLED: USSDOverlay functionality temporarily disabled -->
        <!--
        <service
            android:name=".services.USSDOverlayService"
            android:enabled="true"
            android:exported="false" />
        -->
        
        <!-- SMS Broadcast Receiver is now registered dynamically only when needed -->
        
    </application>

</manifest>
