<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base translucent layer that adapts to background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B3000000" /> <!-- 70% black for better contrast -->
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Blur effect simulation -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#26FFFFFF"
                android:centerColor="#1AFFFFFF"
                android:endColor="#0DFFFFFF"
                android:angle="135" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Subtle inner shadow -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:endColor="#0A000000"
                android:angle="90" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
