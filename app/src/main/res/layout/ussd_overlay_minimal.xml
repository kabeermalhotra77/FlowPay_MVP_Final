<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    
    <!-- Main Container with fixed height -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="vertical"
        android:background="@drawable/overlay_background_premium"
        android:elevation="2dp">

        <!-- Header Section with Brand: 45dp -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="45dp">
            
            <!-- Brand Text -->
            <TextView
                android:id="@+id/tvBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FlowPay"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="24dp"
                android:letterSpacing="0.02" />
            
            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFFLINE UPI"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:letterSpacing="0.1" />
            
            <!-- Close Button -->
            <FrameLayout
                android:id="@+id/btnCloseContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp">
                
                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/close_button_background" />
                
                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_close"
                    android:tint="#666666"
                    android:padding="8dp" />
            </FrameLayout>
        
        </FrameLayout>
        
        <!-- Elegant Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#E8E8E8" />
        
        <!-- Content Section: 85dp -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="85dp">
            
            <!-- Background Accent -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/content_background_accent"
                android:alpha="0.03" />
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">
                
                <!-- Main Instruction -->
                <TextView
                    android:id="@+id/tvInstruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paste payment address"
                    android:textColor="#000000"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="normal"
                    android:gravity="center"
                    android:letterSpacing="0.01"
                    android:includeFontPadding="false" />
                
                <!-- Helper Text with Container -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/helper_text_background"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    
                    <TextView
                        android:id="@+id/tvHelper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="example@upi"
                        android:textColor="#4A4A4A"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:letterSpacing="0.02" />
                </LinearLayout>
            
            </LinearLayout>
        
        </FrameLayout>
        
        <!-- Footer Section: 40dp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="vertical">
            
            <!-- Step Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:orientation="horizontal">
                
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/step_dot_active" />
                
                <TextView
                    android:id="@+id/tvStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 of 5"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.05" />
                
            </LinearLayout>
            
            <!-- Progress Bar Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="16dp">
                
                <!-- Progress Background with padding -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/progress_background" />
                
                <!-- Animated Progress -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:progressDrawable="@drawable/progress_drawable_premium"
                    android:max="100"
                    android:progress="20" />
                
            </FrameLayout>
        
        </LinearLayout>

    </LinearLayout>

</FrameLayout>