<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="false"
    android:focusable="false"
    android:padding="24dp"
    android:clipToPadding="false">

    <!-- Main overlay card with heavy blur effect -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/overlayContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/frosted_glass_background"
        android:elevation="16dp"
        android:minHeight="320dp"
        android:clickable="true"
        android:focusable="true">

        <!-- FlowPay Logo - Refined styling -->
        <TextView
            android:id="@+id/flowPayLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlowPay"
            android:textSize="20sp"
            android:textStyle="normal"
            android:fontFamily="sans-serif-medium"
            android:textColor="#2C2C2C"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Security Badge -->
        <LinearLayout
            android:id="@+id/securityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/success_badge_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/flowPayLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_check_circle"
                android:tint="#4CAF50" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure Transfer"
                android:textSize="13sp"
                android:textStyle="normal"
                android:textColor="#4CAF50"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Main Status - Much Bigger -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Processing Payment"
            android:textSize="24sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/securityBadge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Large Progress Bar Container -->
        <FrameLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/statusText">

            <!-- White track background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/white_progress_track" />

            <!-- Smooth Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/dialer_style_progress" />

            <!-- Percentage overlay -->
            <TextView
                android:id="@+id/progressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Current Step - Larger Font -->
        <TextView
            android:id="@+id/stepText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting to bank..."
            android:textSize="16sp"
            android:textColor="#424242"
            android:textStyle="normal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/progressContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Transaction Details - Bigger and Bolder -->
        <LinearLayout
            android:id="@+id/detailsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/white_card_bg"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/stepText">

            <!-- Amount -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/amountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="24sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amount"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#E0E0E0"
                android:layout_gravity="center" />

            <!-- Recipient -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                
                <TextView
                    android:id="@+id/currentStepText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="••••••0000"
                    android:textSize="20sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Muted Audio Indicator - More Prominent -->
        <LinearLayout
            android:id="@+id/mutedIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/muted_pill_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/detailsCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_volume_off"
                android:tint="#FF6B6B" />
            
            <TextView
                android:id="@+id/instructionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio muted for security"
                android:textSize="14sp"
                android:textStyle="normal"
                android:textColor="#FF6B6B"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Terminate Call Button -->
        <Button
            android:id="@+id/terminateButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/terminate_button_bg"
            android:text="TERMINATE"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_phone_hangup"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/mutedIndicator"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>